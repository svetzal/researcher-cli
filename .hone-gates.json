{
  "gates": [
    {
      "name": "lint",
      "command": "uv run ruff check",
      "required": true
    },
    {
      "name": "format",
      "command": "uv run ruff format --check",
      "required": true
    },
    {
      "name": "test",
      "command": "uv run pytest",
      "required": true
    },
    {
      "name": "security-audit",
      "command": "uv run pip-audit",
      "required": true
    }
  ]
}
